{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RestReminder",
  "version": "1.0.0",
  "identifier": "com.restreminder.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rest Reminder",
        "width": 500,
        "height": 800,
        "minWidth": 450,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "reminder",
        "title": "提醒",
        "width": 400,
        "height": 550,
        "minWidth": 400,
        "minHeight": 550,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity"
  }
}